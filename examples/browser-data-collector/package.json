{
  "name": "argsre-browser-data-collector-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "mock": "node src/mock-server.js",
    "collect:valid": "node src/collector.js --mode valid",
    "collect:quick": "node src/collector.js --mode quick",
    "collect:fingerprint": "node src/collector.js --mode fingerprint",
    "daily:once": "node src/daily-report.js",
    "daily:schedule": "node src/daily-scheduler.js",
    "daily:validate": "node src/validate-config.js",
    "task:preview": "powershell -ExecutionPolicy Bypass -File scripts/manage-daily-task.ps1 -Action Preview",
    "doctor": "node src/doctor.js",
    "probe": "node src/probe.js",
    "inspect": "node src/inspect-probe.js",
    "report": "node src/report.js",
    "test:config": "node src/run-config-validation-demo.js",
    "test:collector": "node src/run-demo.js",
    "test:daily": "node src/run-daily-report-demo.js",
    "test:history": "node src/run-history-demo.js",
    "test:manual": "node src/run-manual-file-demo.js",
    "test:probe": "node src/run-probe-demo.js",
    "test": "npm run test:config && npm run test:collector && npm run test:probe && npm run test:manual && npm run test:history && npm run test:daily"
  },
  "dependencies": {
    "playwright-core": "^1.57.0"
  }
